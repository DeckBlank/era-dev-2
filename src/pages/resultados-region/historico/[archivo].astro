---
import Layout from "../../../layouts/Layout.astro";
import ResultadosUI from "../../../components/ResultadosUI.astro";
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  const historyDir = path.join(process.cwd(), "src/scripts/history");
  if (!fs.existsSync(historyDir)) {
    return [];
  }
  
  const files = fs.readdirSync(historyDir).filter(f => f.endsWith(".json"));
  files.sort().reverse();

  return files.map((filename) => {
    return {
      params: { archivo: filename.replace('.json', '') },
      props: { 
        filename: filename,
        archivosHistorico: files
      },
    };
  });
}

const { filename, archivosHistorico } = Astro.props;

// Load current data as the primary display
import { readFileSync } from "node:fs";
const currentPath = path.join(process.cwd(), "src/scripts/porcentajesPresidencialesPorRegion.json");

let datos;
try {
  const content = readFileSync(currentPath, "utf-8");
  datos = JSON.parse(content);
} catch (e) {
  datos = {
    resultados: [],
    generadoEn: new Date().toISOString(),
    totalRegiones: 0,
    resumenNacional: { actasContabilizadas: 0, top4Candidatos: [] }
  };
}

const { resultados, generadoEn } = datos;
const fecha = new Date(generadoEn).toLocaleString("es-PE", {
  timeZone: "America/Lima",
  dateStyle: "medium",
  timeStyle: "short",
});

const top4 = resultados
  .slice(0, 4)
  .map((r) => `${r.nombre} ${r.porcentajeActasContabilizadas}%`)
  .join(" · ");
const ogDescription = `Elecciones 2026 — Actas por región. ${top4}. Actualizado: ${fecha} (Lima).`;
---

<Layout
  title={`Elecciones 2026 — Resultados por Región`}
  description={ogDescription}
  url={`https://www.eradev2.com/resultados-region/historico/${filename.replace('.json', '')}`}
>
  <ResultadosUI 
    datos={datos} 
    archivosHistorico={archivosHistorico} 
  />
</Layout>

<script define:vars={{ preselect: filename }}>
  // Auto-select the historical file in the dropdown on load
  window.__preselectHistorico = preselect;
</script>

<script>
  // Pre-select the historical dropdown so comparison loads automatically
  const preselect = (window as any).__preselectHistorico;
  if (preselect) {
    const select = document.getElementById("historialSelect") as HTMLSelectElement;
    if (select) {
      select.value = preselect;
      select.dispatchEvent(new Event("change"));
    }
  }
</script>

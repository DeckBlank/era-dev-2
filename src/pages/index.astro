---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ERADEV2 — También era dev">
  <div class="space-y-24">
    <!-- Hero Section -->
    <section class="space-y-6 md:space-y-8 animate-fade-in">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-white tracking-tighter text-glow leading-tight md:whitespace-nowrap">
        También era dev<span class="hidden sm:inline">,</span>
        <span class="text-primary italic font-light text-2xl sm:text-3xl md:text-4xl block sm:inline">eradev2.com</span>
      </h1>
      <p class="font-mono text-sm tracking-widest text-primary/60 uppercase flex items-center gap-1">
        $ <span class="animate-cursor-blink inline-block w-1.5 bg-primary h-5 ml-1"></span>
      </p>
    </section>
    <!-- Narrative Section 01 -->
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import ResultadosUI from "../components/ResultadosUI.astro";
import datos from "../scripts/porcentajesPresidencialesPorRegion.json";
import fs from "node:fs";
import path from "node:path";

// Read history files
let archivosHistorico = [];
try {
  const historyDir = path.join(process.cwd(), "src/scripts/history");
  if (fs.existsSync(historyDir)) {
    archivosHistorico = fs.readdirSync(historyDir).filter(f => f.endsWith(".json"));
    archivosHistorico.sort().reverse(); // Show newest first
  }
} catch (e) {
  console.log("No history found yet");
}

const { resultados, generadoEn, totalRegiones } = datos;
const fecha = new Date(generadoEn).toLocaleString("es-PE", {
  timeZone: "America/Lima",
  dateStyle: "medium",
  timeStyle: "short",
});

const top4 = resultados
  .slice(0, 4)
  .map((r) => `${r.nombre} ${r.porcentajeActasContabilizadas}%`)
  .join(" · ");
const ogDescription = `Elecciones 2026 — Actas presidenciales por región. ${top4}. Actualizado: ${fecha} (Lima).`;
---

<Layout
  title="Elecciones 2026 — Actas presidenciales por región."
  description={ogDescription}
  url="https://www.eradev2.com/resultados-region"
>
  <ResultadosUI 
    datos={datos} 
    archivosHistorico={archivosHistorico} 
    archivoActual="current" 
  />
</Layout>

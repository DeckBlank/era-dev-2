---
import Layout from '../layouts/Layout.astro';
import datos from '../scripts/porcentajesPresidencialesPorRegion.json';

const { resultados, generadoEn, totalRegiones } = datos;
const fecha = new Date(generadoEn).toLocaleString('es-PE', {
  timeZone: 'America/Lima',
  dateStyle: 'medium',
  timeStyle: 'short',
});

const top3 = resultados.slice(0, 3)
  .map(r => `${r.nombre} ${r.porcentajeActasContabilizadas}%`)
  .join(' · ');
const ogDescription = `Elecciones 2026 — Actas presidenciales por región. ${top3}. Actualizado: ${fecha} (Lima).`;
---

<Layout
  title="Elecciones 2026 — Actas presidenciales por región."
  description={ogDescription}
  url="https://www.eradev2.com/resultados-region"
>
  <div class="space-y-8 animate-fade-in">

    <section class="space-y-4">
      <div>
        <p class="font-mono text-xs tracking-widest text-primary/60 uppercase">Elecciones 2026 // Presidencial</p>
        <h1 class="text-2xl font-extrabold text-white tracking-tighter">
          Resultados Nacionales y Regiones
        </h1>
        <p class="text-xs font-medium text-slate-400 mt-2 tracking-wide">
          {totalRegiones} regiones · Última actualización: {fecha} (Lima)
        </p>
      </div>

      <!-- Resumen Nacional -->
      {datos.resumenNacional && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          
          <div class="bg-white/[0.02] border border-white/5 rounded-xl p-5 shadow-2xl backdrop-blur-md relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <p class="font-mono text-[10px] tracking-widest text-slate-400 uppercase mb-2">Total Nacional Contabilizado</p>
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-black text-white tracking-tighter">{datos.resumenNacional.actasContabilizadas}%</span>
            </div>
            
            <div class="mt-4">
               <div class="h-2 w-full bg-white/5 rounded-full overflow-hidden">
                  <div class="h-full bg-primary rounded-full transition-all duration-1000 ease-out" style={`width: ${datos.resumenNacional.actasContabilizadas}%`}></div>
               </div>
            </div>
          </div>

          <div class="bg-white/[0.02] border border-white/5 rounded-xl p-5 shadow-2xl backdrop-blur-md relative overflow-hidden group">
             <div class="absolute inset-0 bg-gradient-to-br from-green-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
             <p class="font-mono text-[10px] tracking-widest text-slate-400 uppercase mb-3">Top 3 Candidatos (Votos Válidos)</p>
             <div class="space-y-3">
               {datos.resumenNacional.top3Candidatos.map((c, i) => (
                 <div class="flex items-center justify-between">
                   <div class="flex items-center gap-3">
                     <span class="flex items-center justify-center w-5 h-5 rounded-full bg-white/10 text-[10px] font-bold text-slate-300">{i + 1}</span>
                     <span class="text-sm font-medium text-slate-200 capitalize leading-tight" style="max-width: 180px; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;" title={c.nombreCandidato}>
                        {c.nombreCandidato.toLowerCase()}
                     </span>
                   </div>
                   <div class="flex flex-col items-end">
                     <span class="font-mono text-xs font-bold text-primary tabular-nums">{c.porcentajeVotosValidos}%</span>
                     <span class="font-mono text-[9px] text-slate-500 tabular-nums tracking-tighter">{c.totalVotosValidos.toLocaleString('es-PE')} votos</span>
                   </div>
                 </div>
               ))}
             </div>
          </div>

        </div>
      )}
    </section>

    <div class="overflow-x-auto rounded-lg border border-white/5">
      <table id="tabla" class="w-full text-sm">
        <thead>
          <tr class="border-b border-white/10 bg-white/5">
            <th data-col="nombre" class="th-sort px-4 py-3 text-left font-mono text-[10px] tracking-widest text-primary/70 uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap">
              Región <span class="sort-icon ml-1 opacity-40">↕</span>
            </th>
            <th data-col="actasContabilizadas" class="hidden sm:table-cell th-sort px-4 py-3 text-right font-mono text-[10px] tracking-widest text-primary/70 uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap">
              Actas ✓ <span class="sort-icon ml-1 opacity-40">↕</span>
            </th>
            <th data-col="porcentajeActasContabilizadas" class="th-sort px-4 py-3 text-left font-mono text-[10px] tracking-widest text-primary/70 uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap">
              % Contabilizadas <span class="sort-icon ml-1 opacity-40">↕</span>
            </th>
            <th data-col="actasPendientes" class="hidden sm:table-cell th-sort px-4 py-3 text-right font-mono text-[10px] tracking-widest text-primary/70 uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap">
              Actas ✗ <span class="sort-icon ml-1 opacity-40">↕</span>
            </th>
            <th data-col="porcentajeActasPendientes" class="hidden sm:table-cell th-sort px-4 py-3 text-right font-mono text-[10px] tracking-widest text-primary/70 uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap">
              % Pendientes <span class="sort-icon ml-1 opacity-40">↕</span>
            </th>
          </tr>
        </thead>
        <tbody id="tbody">
          {resultados.map((r, i) => (
            <tr
              class="border-b border-white/5 hover:bg-white/[0.03] transition-colors"
              data-nombre={r.nombre}
              data-actas-contabilizadas={r.actasContabilizadas}
              data-pct-contabilizadas={r.porcentajeActasContabilizadas}
              data-actas-pendientes={r.actasPendientes}
              data-pct-pendientes={r.porcentajeActasPendientes}
            >
              <td class="px-4 py-3 font-medium text-slate-200 whitespace-nowrap">{r.nombre}</td>
              <td class="hidden sm:table-cell px-4 py-3 text-right font-mono text-slate-400">{r.actasContabilizadas.toLocaleString()}</td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-3 min-w-[160px]">
                  <div class="flex-1 h-1.5 bg-white/10 rounded-full overflow-hidden">
                    <div
                      class="h-full bg-primary rounded-full"
                      style={`width: ${r.porcentajeActasContabilizadas}%`}
                    />
                  </div>
                  <span class="font-mono text-xs text-slate-300 w-12 text-right shrink-0">
                    {r.porcentajeActasContabilizadas}%
                  </span>
                </div>
              </td>
              <td class="hidden sm:table-cell px-4 py-3 text-right font-mono text-slate-400">{r.actasPendientes.toLocaleString()}</td>
              <td class="hidden sm:table-cell px-4 py-3 text-right font-mono text-slate-500">{r.porcentajeActasPendientes}%</td>

            </tr>
          ))}
        </tbody>
      </table>
    </div>

  </div>
</Layout>

<script>
  type SortDir = 'asc' | 'desc';
  type ColKey = 'nombre' | 'actasContabilizadas' | 'porcentajeActasContabilizadas' | 'actasPendientes' | 'porcentajeActasPendientes';

  const dataAttr: Record<ColKey, string> = {
    nombre: 'nombre',
    actasContabilizadas: 'actasContabilizadas',
    porcentajeActasContabilizadas: 'pctContabilizadas',
    actasPendientes: 'actasPendientes',
    porcentajeActasPendientes: 'pctPendientes',
  };

  let currentCol: ColKey | null = null;
  let currentDir: SortDir = 'desc';

  const tbody = document.getElementById('tbody')!;
  const headers = document.querySelectorAll<HTMLTableCellElement>('.th-sort');

  headers.forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.col as ColKey;
      if (currentCol === col) {
        currentDir = currentDir === 'asc' ? 'desc' : 'asc';
      } else {
        currentCol = col;
        currentDir = col === 'nombre' ? 'asc' : 'desc';
      }
      sortTable(col, currentDir);
      updateIcons(th, currentDir);
    });
  });

  function sortTable(col: ColKey, dir: SortDir) {
    const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr'));
    const attr = dataAttr[col];

    rows.sort((a, b) => {
      const av = a.dataset[attr] ?? '';
      const bv = b.dataset[attr] ?? '';
      const isNum = col !== 'nombre';
      const cmp = isNum ? parseFloat(av) - parseFloat(bv) : av.localeCompare(bv, 'es');
      return dir === 'asc' ? cmp : -cmp;
    });

    rows.forEach(r => tbody.appendChild(r));
  }

  function updateIcons(active: HTMLTableCellElement, dir: SortDir) {
    headers.forEach(th => {
      const icon = th.querySelector('.sort-icon')!;
      if (th === active) {
        icon.textContent = dir === 'asc' ? '↑' : '↓';
        icon.classList.remove('opacity-40');
        icon.classList.add('text-primary');
      } else {
        icon.textContent = '↕';
        icon.classList.add('opacity-40');
        icon.classList.remove('text-primary');
      }
    });
  }
</script>

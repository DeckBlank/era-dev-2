            Proyección Final
          </h2>
          <span
            class="text-[9px] font-black uppercase tracking-[0.2em] text-violet-500 bg-violet-500/10 border border-violet-500/20 px-3 py-1 rounded-full"
          >
            Regresión ponderada
          </span>
        </div>

        <div
          class="flex items-center gap-4 bg-slate-50 dark:bg-white/[0.03] border border-black/5 dark:border-white/10 rounded-2xl px-5 py-3 min-w-[320px] shadow-sm"
        >
          <span
            class="text-[10px] font-black text-slate-400 tabular-nums uppercase tracking-tighter"
            >Min +2%</span
          >
          <input
            type="range"
            id="extrapSpinner"
            min="2"
            max={maxExtrap}
            step="0.5"
            value={EXTRAPOLATION_DEFAULT}
            class="extrap-slider flex-1 h-2 appearance-none bg-black/10 dark:bg-white/10 rounded-full cursor-pointer outline-none"
          />
          <span
            class="text-[10px] font-black text-slate-400 tabular-nums uppercase tracking-tighter"
            >Máx +{maxExtrap}%</span
          >
          <div
            class="pl-4 border-l border-black/5 dark:border-white/10 flex flex-col items-end"
          >
            <span
              class="text-[8px] font-black text-slate-400 uppercase tracking-widest mb-0.5"
              >Objetivo</span

        id="proyeccionError"
        style="display: none;"
        class="bg-red-50 dark:bg-red-900/10 border border-red-200 dark:border-red-800/30 rounded-xl p-4 text-xs text-red-700 dark:text-red-400"
      >
      </div>
    </section>
  </section>

  <div
    class="col-span-12 overflow-x-auto rounded-2xl border border-black/5 dark:border-white/5 bg-slate-50/50 dark:bg-white/[0.01] backdrop-blur-sm"
  >
    <p
      class="font-mono text-[10px] tracking-widest text-slate-500 dark:text-slate-400 uppercase font-bold text-center py-6 border-b border-black/5 dark:border-white/5"
    >
      Conteo de Actas por Provincia
    </p>
    <table id="tabla" class="w-full text-sm">
      <thead>
        <tr
          class="border-b border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5"
        >
          <th
            data-col="nombre"
            class="w-[1%] th-sort px-6 py-4 text-left font-mono text-[10px] tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap font-bold"
          >
            Región <span class="sort-icon ml-1 opacity-40 text-sm">↕</span>
          </th>
          <th
            data-col="actasContabilizadas"
            class="w-[1%] hidden sm:table-cell th-sort px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap font-bold"
          >
            Contadas <span class="sort-icon ml-1 opacity-40 text-sm">↕</span>
          </th>
          <th
            data-col="porcentajeActasContabilizadas"
            class="w-[1%] th-sort px-6 py-4 text-left font-mono text-[10px] tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap font-bold"
          >
            % <span class="sort-icon ml-1 opacity-40 text-sm">↕</span>
          </th>
          <th
            data-col="actasPendientes"
            class="w-[1%] hidden sm:table-cell th-sort px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap font-bold"
          >
            Pendientes <span class="sort-icon ml-1 opacity-40 text-sm">↕</span>
          </th>
          <th
            data-col="porcentajeActasPendientes"
            class="w-[1%] hidden sm:table-cell th-sort px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap font-bold"
          >
            % <span class="sort-icon ml-1 opacity-40 text-sm">↕</span>
          </th>
        </tr>
      </thead>
      <tbody id="tbody">
        {
          resultados.map((r) => (
            <tr
              class={`border-b border-black/5 dark:border-white/5 hover:bg-primary/[0.03] transition-colors group/row ${r.actasPendientes === 0 ? "row-complete hidden" : ""}`}
              data-nombre={r.nombre}
              data-actas-contabilizadas={r.actasContabilizadas}
              data-pct-contabilizadas={r.porcentajeActasContabilizadas}
              data-actas-pendientes={r.actasPendientes}
              data-pct-pendientes={r.porcentajeActasPendientes}
            >
              <td class="px-6 py-4 font-bold text-slate-800 dark:text-slate-100 whitespace-nowrap transition-colors group-hover/row:text-primary">
                {r.nombre}
                {r.actasPendientes === 0 && (
                  <span class="ml-2 text-[9px] font-black uppercase tracking-widest text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30 px-2 py-0.5 rounded-full">
                    100%
                  </span>
                )}
              </td>
              <td class="hidden sm:table-cell px-6 py-4 text-right font-mono text-xs text-slate-500 dark:text-slate-400">
                {r.actasContabilizadas.toLocaleString()}
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-2">
                  <span class="font-mono text-[11px] font-bold text-slate-700 dark:text-slate-300">
                    {r.porcentajeActasContabilizadas}%
                  </span>
                  <span
                    class="comparar-data region-diff font-mono text-[10px] font-bold tabular-nums whitespace-nowrap"
                    style="display: none;"
                    data-region-diff={r.nombre}
                  />
                </div>
              </td>
              <td class="hidden sm:table-cell px-6 py-4 text-right font-mono text-xs text-slate-500 dark:text-slate-400">
                {r.actasPendientes.toLocaleString()}
              </td>
              <td class="hidden sm:table-cell px-6 py-4 text-right font-mono text-xs text-slate-500 dark:text-slate-500">
                {r.porcentajeActasPendientes}%
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
    {
      resultados.filter((r) => r.actasPendientes === 0).length > 0 && (
        <button
          id="toggleComplete"
          type="button"
          class="mt-3 w-full flex items-center justify-center gap-2 py-2.5 text-[11px] font-bold uppercase tracking-widest text-emerald-600 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 rounded-xl transition-colors cursor-pointer"
        >
          <span
            id="toggleCompleteIcon"
            class="transition-transform duration-200"
          >
            ▸
          </span>
          <span id="toggleCompleteText">
            Mostrar {resultados.filter((r) => r.actasPendientes === 0).length}{" "}
            regiones al 100%
          </span>
        </button>
      )
    }
  </div>

  {/* Tabla Extranjero */}
  {
    resultadosExtranjero && resultadosExtranjero.length > 0 && (
      <div class="col-span-12 overflow-x-auto rounded-2xl border border-black/5 dark:border-white/5 bg-slate-50/50 dark:bg-white/[0.01] backdrop-blur-sm">
        <p class="font-mono text-[10px] tracking-widest text-slate-500 dark:text-slate-400 uppercase font-bold text-center py-6 border-b border-black/5 dark:border-white/5">
          Conteo de Actas Extranjero
        </p>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5">
              <th class="w-[1%] px-6 py-4 text-left font-mono text-[10px] tracking-widest text-primary uppercase whitespace-nowrap font-bold">
                Continente
              </th>
              <th class="w-[1%] hidden sm:table-cell px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase whitespace-nowrap font-bold">
                Total Actas
              </th>
              <th class="w-[1%] hidden sm:table-cell px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase whitespace-nowrap font-bold">
                Contadas
              </th>
              <th class="w-[1%] px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase whitespace-nowrap font-bold">
                %
              </th>
              <th class="w-[1%] hidden sm:table-cell px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase whitespace-nowrap font-bold">
                Pendientes JEE
              </th>
              <th class="w-[1%] hidden sm:table-cell px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase whitespace-nowrap font-bold">
                %
              </th>
              <th class="w-[1%] hidden sm:table-cell px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase whitespace-nowrap font-bold">
                Votos Válidos
              </th>
              {/*  <th class="w-[1%] hidden sm:table-cell px-6 py-4 text-right font-mono text-[10px] tracking-widest text-primary uppercase whitespace-nowrap font-bold">
                Part. %
              </th> */}
            </tr>
          </thead>
          <tbody>
            {resultadosExtranjero.map((r) => (
              <tr class="border-b border-black/5 dark:border-white/5 hover:bg-primary/[0.03] transition-colors">
                <td class="px-6 py-4 font-bold text-slate-800 dark:text-slate-100 whitespace-nowrap capitalize">
                  {r.nombre.charAt(0) + r.nombre.slice(1).toLowerCase()}
                </td>
                <td class="hidden sm:table-cell px-6 py-4 text-right font-mono text-xs text-slate-500 dark:text-slate-400">
                  {r.totalActas?.toLocaleString("es-PE") ?? "-"}
                </td>
                <td class="hidden sm:table-cell px-6 py-4 text-right font-mono text-xs text-slate-500 dark:text-slate-400">
                  {r.actasContabilizadas?.toLocaleString("es-PE") ?? "-"}
                </td>
                <td class="px-6 py-4 text-right font-mono text-[11px] font-bold text-slate-700 dark:text-slate-300">
                  {r.porcentajeActasContabilizadas}%
                </td>
                <td class="hidden sm:table-cell px-6 py-4 text-right font-mono text-xs text-slate-500 dark:text-slate-400">
                  {r.actasPendientes?.toLocaleString("es-PE") ?? "-"}
                </td>
                <td class="hidden sm:table-cell px-6 py-4 text-right font-mono text-xs text-slate-500 dark:text-slate-500">
                  {r.porcentajeActasPendientes}%
                </td>
                <td class="hidden sm:table-cell px-6 py-4 text-right font-mono text-xs text-slate-500 dark:text-slate-400">
                  {r.totalVotosValidos?.toLocaleString("es-PE") ?? "-"}
                </td>
                {/*  <td class="hidden sm:table-cell px-6 py-4 text-right font-mono text-xs text-slate-500 dark:text-slate-400">
                  {r.participacionCiudadana
                    ? `${r.participacionCiudadana}%`
                    : "-"}
                </td> */}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</div>

<script
  define:vars={{
    datosActualesJSON: JSON.stringify(datos),
    archivosHistoricoJSON: JSON.stringify(archivosHistorico),
    _EXTRAPOLATION_DEFAULT: EXTRAPOLATION_DEFAULT,
  }}
>
  window.__datosActuales = JSON.parse(datosActualesJSON);
  window.__EXTRAPOLATION_PERCENT = _EXTRAPOLATION_DEFAULT;
  window.__archivosHistorico = JSON.parse(archivosHistoricoJSON);
</script>

<script>
  const datosActuales = (window as any).__datosActuales;
  const archivosHistorico: string[] = (window as any).__archivosHistorico;

  // ── Comparison logic ──
  const select = document.getElementById(
    "historialSelect",
  ) as HTMLSelectElement;
  const statusEl = document.getElementById("comparacionStatus");

  if (select) {
    select.addEventListener("change", async () => {
      const filename = select.value;

      // Clear comparison
      hideComparison();

      if (!filename) {
        if (statusEl) statusEl.textContent = "";
        return;
      }

      if (statusEl) statusEl.textContent = "Cargando histórico…";

      try {
        const res = await fetch(`/history/${filename}`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const datosHistoricos = await res.json();

        showComparison(datosHistoricos);
        if (statusEl) {
          const fechaHist = new Date(datosHistoricos.generadoEn).toLocaleString(
            "es-PE",
            {
              timeZone: "America/Lima",
              dateStyle: "medium",
              timeStyle: "short",
            },
          );
          statusEl.textContent = `Comparando con snapshot de ${fechaHist}`;
        }
      } catch (err) {
        console.error("Error cargando histórico:", err);
        if (statusEl) statusEl.textContent = "Error al cargar histórico.";
      }
    });
  }

  function hideComparison() {
    document.querySelectorAll<HTMLElement>(".comparar-data").forEach((el) => {
      el.style.display = "none";
      el.innerHTML = "";
    });
  }

  function showComparison(datosHistoricos: any) {
    // ── Diff actas contabilizadas nacionales ──
    const diffActasEl = document.getElementById("diffActas");
    if (
      diffActasEl &&
      datosActuales.resumenNacional &&
      datosHistoricos.resumenNacional
    ) {
      const diffPct = (
        parseFloat(datosActuales.resumenNacional.actasContabilizadas) -
        parseFloat(datosHistoricos.resumenNacional.actasContabilizadas)
      ).toFixed(3);
      const num = parseFloat(diffPct);

      diffActasEl.style.display = "";
      if (num > 0) {
        diffActasEl.textContent = `↑ +${diffPct}%`;
        diffActasEl.className =
          "comparar-data font-medium text-xs font-extra-bold text-green-700 dark:text-green-400 ml-2 shadow-sm bg-green-100 dark:bg-green-900/40 px-2 py-0.5 rounded border border-green-300 dark:border-green-700/50";
      } else if (num < 0) {
        diffActasEl.textContent = `↓ ${diffPct}%`;
        diffActasEl.className =
          "comparar-data font-medium text-xs font-extra-bold text-red-700 dark:text-red-400 ml-2 shadow-sm bg-red-100 dark:bg-red-900/40 px-2 py-0.5 rounded border border-red-300 dark:border-red-700/50";
      } else {
        diffActasEl.textContent = `= 0%`;
        diffActasEl.className =
          "comparar-data font-medium text-xs font-extra-bold text-slate-600 dark:text-slate-400 ml-2 shadow-sm bg-slate-100 dark:bg-slate-900/40 px-2 py-0.5 rounded border border-slate-300 dark:border-slate-700/50";
      }
    }

    function formatCandidateName(name: string) {
      const words = name.toLowerCase().split(/\s+/);
      if (words.length > 3) {
        words.splice(1, 1);
      }
      return words.join(" ");
    }

    // ── Fetch snapshots and build map ──
    if (
      datosActuales.resumenNacional?.top4Candidatos &&
      datosHistoricos.resumenNacional?.top4Candidatos
    ) {
      datosActuales.resumenNacional.top4Candidatos.forEach((cActual: any) => {
        const cHistorico = datosHistoricos.resumenNacional.top4Candidatos.find(
          (h: any) => h.nombreCandidato === cActual.nombreCandidato,
        );

        if (!cHistorico) return;

        const diffEl = document.querySelector<HTMLElement>(
          `[data-candidato-diff="${cActual.nombreCandidato}"]`,
        );
        if (!diffEl) return;

        const diffPct = (
          parseFloat(cActual.porcentajeVotosValidos) -
          parseFloat(cHistorico.porcentajeVotosValidos)
        ).toFixed(3);
        const diffVotos =
          cActual.totalVotosValidos - cHistorico.totalVotosValidos;
        const numPct = parseFloat(diffPct);

        const bgColor =
          numPct > 0
            ? "bg-green-100 dark:bg-green-900/40 border-green-300 dark:border-green-700/50 text-green-700 dark:text-green-400"
            : numPct < 0
              ? "bg-red-100 dark:bg-red-900/40 border-red-300 dark:border-red-700/50 text-red-700 dark:text-red-400"
              : "bg-slate-100 dark:bg-slate-900/40 border-slate-300 dark:border-slate-700/50 text-slate-600 dark:text-slate-400";

        diffEl.className = `comparar-data candidato-diff flex flex-col items-end mt-1.5 p-1 px-2 border rounded shadow-sm animate-fade-in origin-top ${bgColor}`;

        const pctArrow = numPct > 0 ? "↑ +" : numPct < 0 ? "↓ " : "";
        const votosPrefix = diffVotos > 0 ? "+" : "";

        diffEl.innerHTML = `
          <span class="font-bold text-[10px] tabular-nums leading-tight">
            ${pctArrow}${numPct !== 0 ? diffPct : "0"}%
          </span>
          <span class="text-[9px] font-medium tabular-nums opacity-90 leading-tight">
            ${votosPrefix}${diffVotos.toLocaleString("es-PE")} votos
          </span>
        `;
        diffEl.style.display = "";
      });
    }

    // ── Diff Stats Globales (Cards) ──
    if (datosActuales.resumenNacional && datosHistoricos.resumenNacional) {
      document.querySelectorAll<HTMLElement>(".stat-diff").forEach((el) => {
        const stat = el.dataset.stat;
        if (!stat) return;

        const actual = datosActuales.resumenNacional[stat] || 0;
        const historico = datosHistoricos.resumenNacional[stat] || 0;
        const diff = Number(actual) - Number(historico);

        if (diff === 0 || isNaN(diff)) return;

        const isPct =
          stat === "participacionCiudadana" ||
          stat.includes("porcentaje") ||
          stat.includes("Porcentaje");
        const diffFormat = isPct
          ? diff.toFixed(3)
          : diff.toLocaleString("es-PE");
        const prefix = diff > 0 ? "+" : "";
        const arrow = diff > 0 ? "↑" : "↓";

        // Normalmente subir es bueno (verde), bajar es malo (rojo)
        let color =
          diff > 0
            ? "text-green-700 dark:text-green-400 bg-green-100 dark:bg-green-900/30 px-1.5 py-0.5 rounded"
            : "text-red-700 dark:text-red-400 bg-red-100 dark:bg-red-900/30 px-1.5 py-0.5 rounded";

        // Excepción: si es pendientes JEE, subir es malo (rojo), bajar es bueno (verde)
        if (stat === "pendientesJee" || stat === "actasPendientesJee") {
          color =
            diff > 0
              ? "text-red-700 dark:text-red-400 bg-red-100 dark:bg-red-900/30 px-1.5 py-0.5 rounded"
              : "text-green-700 dark:text-green-400 bg-green-100 dark:bg-green-900/30 px-1.5 py-0.5 rounded";
        }

        // Add font size styles if missing
        el.className = `comparar-data stat-diff text-[10px] font-bold tabular-nums ml-1.5 inline-flex items-center leading-none ${color}`;
        if (el.dataset.stat === "totalVotosEmitidos") {
          el.className = el.className.replace("text-[10px]", "text-[8px]");
        }

        el.innerHTML = `${arrow} ${prefix}${diffFormat}${isPct ? "%" : ""}`;
        el.style.display = "inline-flex";
      });
    }

    // ── Diff regiones en la tabla ──
    if (datosActuales.resultados && datosHistoricos.resultados) {
      datosActuales.resultados.forEach((rActual: any) => {
        const rHist = datosHistoricos.resultados.find(
          (h: any) => h.nombre === rActual.nombre,
        );
        if (!rHist) return;

        const diffEl = document.querySelector<HTMLElement>(
          `[data-region-diff="${rActual.nombre}"]`,
        );
        if (!diffEl) return;

        const diffPct = (
          rActual.porcentajeActasContabilizadas -
          rHist.porcentajeActasContabilizadas
        ).toFixed(3);
        const numPct = parseFloat(diffPct);
        const diffActas =
          rActual.actasContabilizadas - rHist.actasContabilizadas;

        if (numPct === 0 && diffActas === 0) return;

        const color =
          numPct > 0
            ? "text-green-700 dark:text-green-400"
            : numPct < 0
              ? "text-red-700 dark:text-red-400"
              : "text-slate-500";

        const arrow = numPct > 0 ? "↑+" : numPct < 0 ? "↓" : "";
        const actasPrefix = diffActas > 0 ? "+" : "";

        diffEl.className = `comparar-data region-diff font-mono text-[10px] font-bold tabular-nums whitespace-nowrap ${color}`;
        diffEl.innerHTML = `${arrow}${diffPct}% <span class="font-normal text-[9px] opacity-70">(${actasPrefix}${diffActas})</span>`;
        diffEl.style.display = "";
      });
    }
  }

  // ── Table sorting ──
  type SortDir = "asc" | "desc";
  type ColKey =
    | "nombre"
    | "actasContabilizadas"
    | "porcentajeActasContabilizadas"
    | "actasPendientes"
    | "porcentajeActasPendientes";

  const dataAttr: Record<ColKey, string> = {
    nombre: "nombre",
    actasContabilizadas: "actasContabilizadas",
    porcentajeActasContabilizadas: "pctContabilizadas",
    actasPendientes: "actasPendientes",
    porcentajeActasPendientes: "pctPendientes",
  };

  let currentCol: ColKey | null = null;
  let currentDir: SortDir = "desc";

  const tbody = document.getElementById("tbody");
  const headers = document.querySelectorAll<HTMLTableCellElement>(".th-sort");

  if (tbody) {
    headers.forEach((th) => {
      th.addEventListener("click", () => {
        const col = th.dataset.col as ColKey;
        if (currentCol === col) {
          currentDir = currentDir === "asc" ? "desc" : "asc";
        } else {
          currentCol = col;
          currentDir = col === "nombre" ? "asc" : "desc";
        }
        sortTable(col, currentDir);
        updateIcons(th, currentDir);
      });
    });
  }

  function sortTable(col: ColKey, dir: SortDir) {
    if (!tbody) return;
    const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>("tr"));
    const attr = dataAttr[col];

    rows.sort((a, b) => {
      const av = a.dataset[attr] ?? "";
      const bv = b.dataset[attr] ?? "";
      const isNum = col !== "nombre";
      const cmp = isNum
        ? parseFloat(av) - parseFloat(bv)
        : av.localeCompare(bv, "es");
      return dir === "asc" ? cmp : -cmp;
    });

    rows.forEach((r) => tbody.appendChild(r));
  }

  function updateIcons(active: HTMLTableCellElement, dir: SortDir) {
    headers.forEach((th) => {
      const icon = th.querySelector(".sort-icon");
      if (!icon) return;
      if (th === active) {
        icon.textContent = dir === "asc" ? "↑" : "↓";
        icon.classList.remove("opacity-40");
        icon.classList.add("text-primary");
      } else {
        icon.textContent = "↕";
        icon.classList.add("opacity-40");
        icon.classList.remove("text-primary");
      }
    });
  }

  // ══════════════════════════════════════════════════
  // ── PROYECCIÓN DE RESULTADOS (Regresión Lineal) ──
  // ══════════════════════════════════════════════════

  const loadingEl = document.getElementById("proyeccionLoading");
  const contentEl = document.getElementById("proyeccionContent");
  const errorEl = document.getElementById("proyeccionError");
  const candidatosEl = document.getElementById("proyeccionCandidatos");
  const metaEl = document.getElementById("proyeccionMeta");

  function formatCandidateName(name: string) {
    const words = name.toLowerCase().split(/\s+/);
    if (words.length > 3) {
      // Elimina el segundo nombre si hay 4 o más palabras
      words.splice(1, 1);
    }
    return words.join(" ");
  }

  const CANDIDATO_COLORS = [
    "from-violet-500 to-purple-600",
    "from-blue-500 to-cyan-600",
    "from-amber-500 to-orange-600",
    "from-emerald-500 to-teal-600",
  ];

  interface DataPoint {
    actasPct: number;
    candidatoPct: number;
    timestamp: number;
  }

  interface CandidatoTimeline {
    nombre: string;
    puntos: DataPoint[];
    actual: number;
    actualVotos: number;
  }

  /**
   * Regresión lineal ponderada (Weighted Least Squares).
   * Cada punto lleva un peso `w` que indica su importancia relativa.
   * Puntos con mayor w influyen más en la pendiente e intercepto.
   */
  function linearRegression(points: { x: number; y: number; w: number }[]) {
    const n = points.length;
    if (n < 2) return null;

    // Sumas ponderadas
    let W = 0,
      sumWX = 0,
      sumWY = 0,
      sumWXY = 0,
      sumWX2 = 0;
    for (const p of points) {
      const w = p.w;
      W += w;
      sumWX += w * p.x;
      sumWY += w * p.y;
      sumWXY += w * p.x * p.y;
      sumWX2 += w * p.x * p.x;
    }

    const denom = W * sumWX2 - sumWX * sumWX;
    if (Math.abs(denom) < 1e-10) return null;

    const slope = (W * sumWXY - sumWX * sumWY) / denom;
    const intercept = (sumWY - slope * sumWX) / W;

    // R² ponderado
    const meanYW = sumWY / W;
    let ssTot = 0,
      ssRes = 0;
    for (const p of points) {
      ssTot += p.w * (p.y - meanYW) ** 2;
      ssRes += p.w * (p.y - (slope * p.x + intercept)) ** 2;
    }
    const r2 = ssTot > 0 ? 1 - ssRes / ssTot : 0;

    return { slope, intercept, r2 };
  }

  // ── Datos cacheados para recálculo rápido ──
  let cachedCandidatoMap: Map<string, CandidatoTimeline> | null = null;
  let cachedSnapshotCount = 0;

  async function loadSnapshots(): Promise<boolean> {
    try {
      const filesToFetch = archivosHistorico.slice(0, 15);

      if (filesToFetch.length < 2) {
        showProjectionError(
          "Se necesitan al menos 2 snapshots históricos para proyectar.",
        );
        return false;
      }

      const results = await Promise.allSettled(
        filesToFetch.map(async (f: string) => {
          const res = await fetch(`/history/${f}`);
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          return await res.json();
        }),
      );

      const snapshots = results
        .filter(
          (r): r is PromiseFulfilledResult<any> => r.status === "fulfilled",
        )
        .map((r) => r.value)
        .filter(
          (d: any) =>
            d.resumenNacional?.top4Candidatos &&
            d.resumenNacional.actasContabilizadas,
        );

      if (datosActuales.resumenNacional?.top4Candidatos) {
        snapshots.unshift(datosActuales);
      }

      if (snapshots.length < 3) {
        showProjectionError(
          "Datos insuficientes para una proyección confiable.",
        );
        return false;
      }

      // Timeline por candidato
      const candidatoMap = new Map<string, CandidatoTimeline>();

      for (const c of datosActuales.resumenNacional.top4Candidatos) {
        candidatoMap.set(c.nombreCandidato, {
          nombre: c.nombreCandidato,
          puntos: [],
          actual: c.porcentajeVotosValidos,
          actualVotos: c.totalVotosValidos,
        });
      }

      for (const snap of snapshots) {
        const actasPct = parseFloat(snap.resumenNacional.actasContabilizadas);
        const ts = new Date(snap.generadoEn).getTime();

        for (const c of snap.resumenNacional.top4Candidatos) {
          const timeline = candidatoMap.get(c.nombreCandidato);
          if (!timeline) continue;

          const exists = timeline.puntos.some(
            (p: DataPoint) => Math.abs(p.actasPct - actasPct) < 0.001,
          );
          if (!exists) {
            timeline.puntos.push({
              actasPct,
              candidatoPct: parseFloat(c.porcentajeVotosValidos),
              timestamp: ts,
            });
          }
        }
      }

      cachedCandidatoMap = candidatoMap;
      cachedSnapshotCount = snapshots.length;
      return true;
    } catch (err) {
      console.error("Error cargando snapshots:", err);
      showProjectionError("Error al cargar los datos históricos.");
      return false;
    }
  }

  function recalcProjection(extrapPct: number) {
    if (!cachedCandidatoMap) return;

    const actasPctActual = parseFloat(
      datosActuales.resumenNacional.actasContabilizadas,
    );
    const targetX = Math.min(actasPctActual + extrapPct, 100);

    // Actualizar labels dinámicos
    const targetLabel = document.getElementById("targetPctLabel");
    const inlineLabel = document.getElementById("proyeccionTargetInline");
    if (targetLabel) targetLabel.textContent = `${targetX}%`;
    if (inlineLabel) inlineLabel.textContent = `${targetX}`;

    const proyecciones: any[] = [];

    for (const [nombre, timeline] of cachedCandidatoMap) {
      if (timeline.puntos.length < 2) continue;
      timeline.puntos.sort(
        (a: DataPoint, b: DataPoint) => a.actasPct - b.actasPct,
      );

      const timestamps = timeline.puntos.map((p: DataPoint) => p.timestamp);
      const minTs = Math.min(...timestamps);
      const maxTs = Math.max(...timestamps);
      const tsRange = maxTs - minTs || 1;

      const points = timeline.puntos.map((p: DataPoint) => {
        const reliability = (p.actasPct / 100) ** 2;
        const recency = 0.3 + 0.7 * ((p.timestamp - minTs) / tsRange);
        return {
          x: p.actasPct,
          y: p.candidatoPct,
          w: reliability * recency,
        };
      });

      const reg = linearRegression(points);
      if (!reg) continue;

      const proyectado = reg.slope * targetX + reg.intercept;

      let tendencia = "estable";
      if (reg.slope > 0.005) tendencia = "subiendo";
      else if (reg.slope < -0.005) tendencia = "bajando";

      proyecciones.push({
        nombre,
        actual: timeline.actual,
        actualVotos: timeline.actualVotos,
        proyectado: Math.max(0, proyectado),
        tendencia,
        r2: reg.r2,
        puntos: timeline.puntos.length,
        rankActual: 0,
        rankProyectado: 0,
      });
    }

    [...proyecciones]
      .sort((a, b) => b.actual - a.actual)
      .forEach((p, i) => (p.rankActual = i + 1));
    const sortedProy = [...proyecciones].sort(
      (a, b) => b.proyectado - a.proyectado,
    );
    sortedProy.forEach((p, i) => (p.rankProyectado = i + 1));

    renderProjection(sortedProy, cachedSnapshotCount);
  }

  function showProjectionError(msg: string) {
    if (loadingEl) loadingEl.style.display = "none";
    if (errorEl) {
      errorEl.textContent = msg;
      errorEl.style.display = "";
    }
  }

  function renderProjection(proyecciones: any[], totalSnapshots: number) {
    if (loadingEl) loadingEl.style.display = "none";
    if (contentEl) contentEl.style.display = "";
    if (!candidatosEl || !metaEl) return;

    const maxProy = Math.max(...proyecciones.map((p: any) => p.proyectado));

    candidatosEl.innerHTML = proyecciones
      .map((p: any, i: number) => {
        const rankChange = p.rankActual - p.rankProyectado;
        const rankBadge =
          rankChange > 0
            ? `<span class="text-green-600 dark:text-green-400 text-[10px] font-bold">↑${rankChange}</span>`
            : rankChange < 0
              ? `<span class="text-red-600 dark:text-red-400 text-[10px] font-bold">↓${Math.abs(rankChange)}</span>`
              : `<span class="text-slate-400 text-[10px]">=</span>`;

        const tendenciaIcon =
          p.tendencia === "subiendo"
            ? `<span class="text-xs">📈</span>`
            : p.tendencia === "bajando"
              ? `<span class="text-xs">📉</span>`
              : `<span class="text-xs">➡️</span>`;

        const diff = p.proyectado - p.actual;
        const diffStr = diff > 0 ? `+${diff.toFixed(3)}` : diff.toFixed(3);
        const diffColor =
          diff > 0
            ? "text-green-700 dark:text-green-400"
            : diff < 0
              ? "text-red-700 dark:text-red-400"
              : "text-slate-500";

        const barWidth = maxProy > 0 ? (p.proyectado / maxProy) * 100 : 0;
        const barActualWidth = maxProy > 0 ? (p.actual / maxProy) * 100 : 0;
        const color = CANDIDATO_COLORS[i % CANDIDATO_COLORS.length];

        return `
          <div class="space-y-1.5">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <span class="flex items-center justify-center w-5 h-5 rounded-full bg-gradient-to-br ${color} text-white text-[10px] font-bold shadow-sm">
                  ${p.rankProyectado}
                </span>
                <span class="text-sm font-bold text-slate-800 dark:text-slate-200 capitalize leading-tight" style="max-width: 180px; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">
                  ${formatCandidateName(p.nombre)}
                </span>
                ${rankBadge}
                ${tendenciaIcon}
              </div>
              <div class="flex flex-col items-end">
                <span class="text-sm font-black text-slate-900 dark:text-white tabular-nums">
                  ${p.proyectado.toFixed(3)}%
                </span>
                <span class="text-[10px] ${diffColor} font-medium tabular-nums">
                  ${diffStr}% vs actual
                </span>
              </div>
            </div>
            <div class="relative h-2 bg-black/5 dark:bg-white/5 rounded-full overflow-hidden">
              <div class="absolute h-full bg-gradient-to-r ${color} rounded-full transition-all duration-1000 opacity-30" style="width: ${barActualWidth}%"></div>
              <div class="absolute h-full bg-gradient-to-r ${color} rounded-full transition-all duration-1000" style="width: ${barWidth}%"></div>
            </div>
            <div class="flex justify-between text-[9px] text-slate-400 tabular-nums">
              <span>Actual: ${p.actual}%</span>
              <span>R²: ${p.r2.toFixed(4)}</span>
            </div>
          </div>
        `;
      })
      .join("");

    // Meta info
    const actasPct = datosActuales.resumenNacional?.actasContabilizadas ?? "?";
    const totalPuntos = proyecciones.reduce(
      (s: number, p: any) => s + p.puntos,
      0,
    );

    metaEl.innerHTML = `
      <div class="space-y-3">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-primary"></span>
          <span>Actas contabilizadas: <strong class="text-slate-800 dark:text-white">${actasPct}%</strong></span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-violet-500"></span>
          <span>Snapshots analizados: <strong class="text-slate-800 dark:text-white">${totalSnapshots}</strong></span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-amber-500"></span>
          <span>Puntos de datos: <strong class="text-slate-800 dark:text-white">${totalPuntos}</strong></span>
        </div>
        <div class="mt-4 pt-3 border-t border-black/5 dark:border-white/5">
          <p class="text-[10px] text-slate-400 leading-relaxed">
            <strong>Método:</strong> Regresión lineal ponderada (WLS) sobre 
            <code class="bg-black/5 dark:bg-white/5 px-1 rounded text-[9px]">%actas → %votos</code>. 
            Más peso a datos recientes y con mayor cobertura de actas.
            <strong>R²</strong> indica el ajuste de la tendencia (1.0 = perfecto).
          </p>
          <p class="text-[10px] text-slate-400 leading-relaxed mt-2">
            ⚠️ Esta es una <strong>estimación estadística</strong>, no una predicción definitiva.
          </p>
        </div>
      </div>
    `;
  }

  // ── Spinner para ajuste interactivo ──
  const spinner = document.getElementById("extrapSpinner") as HTMLInputElement;
  if (spinner) {
    spinner.addEventListener("input", () => {
      const val = parseFloat(spinner.value);
      if (!isNaN(val) && val >= 2) {
        recalcProjection(val);
      }
    });
  }

  // ── Toggle Candidatos ──
  const toggleBtn = document.getElementById("toggleCandidatos");
  const extraCands = document.getElementById("extraCandidatos");
  const toggleText = document.getElementById("toggleText");

  if (toggleBtn && extraCands && toggleText) {
    toggleBtn.addEventListener("click", () => {
      const isHidden = extraCands.classList.contains("hidden");
      if (isHidden) {
        extraCands.classList.remove("hidden");
        toggleText.textContent = "Ver menos";
        toggleBtn.setAttribute("data-open", "true");
      } else {
        extraCands.classList.add("hidden");
        toggleText.textContent = "Ver todos los candidatos";
        toggleBtn.setAttribute("data-open", "false");
      }
    });
  }

  // ── Toggle Regiones al 100% ──
  const toggleCompleteBtn = document.getElementById("toggleComplete");
  const toggleCompleteIcon = document.getElementById("toggleCompleteIcon");
  const toggleCompleteText = document.getElementById("toggleCompleteText");

  if (toggleCompleteBtn && toggleCompleteIcon && toggleCompleteText) {
    toggleCompleteBtn.addEventListener("click", () => {
      const completeRows = document.querySelectorAll(".row-complete");
      const isHidden = completeRows[0]?.classList.contains("hidden");

      completeRows.forEach((row) => {
        if (isHidden) {
          row.classList.remove("hidden");
        } else {
          row.classList.add("hidden");
        }
      });

      if (isHidden) {
        toggleCompleteIcon.style.transform = "rotate(90deg)";
        toggleCompleteText.textContent = `Ocultar regiones al 100%`;
      } else {
        toggleCompleteIcon.style.transform = "rotate(0deg)";
        toggleCompleteText.textContent = `Mostrar ${completeRows.length} regiones al 100%`;
      }
    });
  }

  // Iniciar: cargar datos una vez, luego calcular con valor default
  loadSnapshots().then((ok) => {
    if (ok) {
      const defaultVal = (window as any).__EXTRAPOLATION_PERCENT ?? 7.5;
      recalcProjection(defaultVal);
    }
  });
</script>


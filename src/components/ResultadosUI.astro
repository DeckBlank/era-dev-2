                          {i + 1}
                        </span>
                        <span
                          class="text-sm font-black text-slate-800 dark:text-slate-100 capitalize leading-tight tracking-tight"
                          style="max-width: 220px; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;"
                          title={c.nombreCandidato}
                        >
                          {formatCandidateName(c.nombreCandidato)}
                        </span>
                      </div>
                      <div class="flex  items-end shrink-0 animate-fade-in space-x-2">
                        <div class="flex flex-col items-end shrink-0">
                          <span class="text-sm font-black text-primary tabular-nums">
                            {c.porcentajeVotosValidos}%
                          </span>
                          <span class="text-[9px] font-bold text-slate-500 dark:text-slate-500 tabular-nums">
                            {c.totalVotosValidos.toLocaleString("es-PE")} votos
                          </span>
                          {i > 0 && (
                            <span
                              class="font-black text-[9px] text-amber-600 dark:text-amber-400/80 px-1.5 py-0.5 mt-0.5 tabular-nums bg-amber-500/10 rounded"
                              title={`Votos para alcanzar a ${datos.resumenNacional.top4Candidatos[i - 1].nombreCandidato}`}
                            >
                              para ↑{" "}
                              {(
                                datos.resumenNacional.top4Candidatos[i - 1]
                                  .totalVotosValidos - c.totalVotosValidos
                              ).toLocaleString("es-PE")}
                            </span>
                          )}
                        </div>
                        <div
                          class="comparar-data candidato-diff"
                          style="display: none;"
                          data-candidato-diff={c.nombreCandidato}
                        />

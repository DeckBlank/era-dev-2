---
export interface Props {
  datos: any;
  archivosHistorico: string[];
}

const { datos, archivosHistorico } = Astro.props;

const { resultados, generadoEn, totalRegiones, resultadosExtranjero } = datos;
const EXTRAPOLATION_DEFAULT = 7.5;
const actasPctActual = parseFloat(datos.resumenNacional.actasContabilizadas);
const maxExtrap = Math.round((100 - actasPctActual) * 10) / 10;
const fecha = new Date(generadoEn).toLocaleString("es-PE", {
  timeZone: "America/Lima",
  dateStyle: "medium",
  timeStyle: "short",
});

function formatOption(filename) {
  const match = filename.match(/porcentajes_(.+)\.json/);
  if (match) {
    let datePart = match[1];
    let parts = datePart.split("T");
    if (parts.length === 2) {
      let timeParts = parts[1].split("-");
      let iso = `${parts[0]}T${timeParts.join(":")}Z`;
      return new Date(iso).toLocaleString("es-PE", {
        timeZone: "America/Lima",
        dateStyle: "medium",
        timeStyle: "short",
      });
    }
  }
  return filename;
}

function formatCandidateName(name) {
  const words = name.toLowerCase().split(/\s+/);
  if (words.length > 3) {
    // Elimina el segundo nombre si hay 4 o más palabras
    words.splice(1, 1);
  }
  return words.join(" ");
}
---


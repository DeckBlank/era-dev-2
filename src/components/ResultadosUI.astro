---
export interface Props {
  datos: any;
  archivosHistorico: string[];
  archivoActual: string;
}

const { datos, archivosHistorico, archivoActual } = Astro.props;
const { resultados, generadoEn, totalRegiones } = datos;
const fecha = new Date(generadoEn).toLocaleString("es-PE", {
  timeZone: "America/Lima",
  dateStyle: "medium",
  timeStyle: "short",
});

function formatOption(filename) {
  if (filename === "current") return "Último reporte (Actual)";
  const match = filename.match(/porcentajes_(.+)\.json/);
  if (match) {
    let datePart = match[1];
    let parts = datePart.split('T');
    if (parts.length === 2) {
      let timeParts = parts[1].split('-');
      // Reconstruct valid ISO string to parse. E.g. "2026-04-14T15:11:52Z"
      let iso = `${parts[0]}T${timeParts.join(':')}Z`;
      return new Date(iso).toLocaleString("es-PE", {
        timeZone: "America/Lima",
        dateStyle: "medium",
        timeStyle: "short",
      });
    }
  }
  return filename;
}
---

<div class="space-y-8 animate-fade-in">
  <section class="space-y-4">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
      <div>
        <p class="font-mono text-xs tracking-widest text-primary uppercase">
          Elecciones 2026 // Presidencial
        </p>
        <h1
          class="text-2xl font-extrabold text-slate-900 dark:text-white tracking-tighter"
        >
          Resultados Nacionales y Regiones
        </h1>
        <p
          class="text-xs font-medium text-slate-600 dark:text-slate-400 mt-2 tracking-wide"
        >
          {totalRegiones} regiones · Actualizado: {fecha}
        </p>
      </div>
    </div>

    <!-- Resumen Nacional -->
    {
      datos.resumenNacional && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-slate-50 dark:bg-white/[0.02] border border-black/5 dark:border-white/5 rounded-xl p-5 shadow-sm dark:shadow-2xl backdrop-blur-md relative overflow-hidden group flex flex-col justify-between">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            
            <div>
              <p class="font-mono text-xs tracking-widest text-slate-600 dark:text-slate-400 uppercase mb-2">
                Total Nacional Contabilizado
              </p>
              <div class="flex items-baseline gap-2 mb-4">
                <span class="text-4xl font-black text-slate-900 dark:text-white tracking-tighter">
                  {datos.resumenNacional.actasContabilizadas}%
                </span>
              </div>
              
              <div class="mt-4 mb-6">
                <div class="h-2 w-full bg-black/5 dark:bg-white/5 rounded-full overflow-hidden">
                  <div
                    class="h-full bg-primary rounded-full transition-all duration-1000 ease-out"
                    style={`width: ${datos.resumenNacional.actasContabilizadas}%`}
                  />
                </div>
              </div>
            </div>

            <div class="z-10 relative mt-4 pt-4 border-t border-black/5 dark:border-white/5">
                <label for="historialSelect" class="block font-mono text-[10px] uppercase text-slate-500 tracking-wider mb-2">Revisar reporte histórico:</label>
                <select id="historialSelect" class="w-full bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-md px-3 py-2 text-xs font-medium focus:ring-1 focus:ring-primary outline-none transition-colors dark:text-white shadow-sm cursor-pointer">
                    <option value="current" selected={archivoActual === 'current'}>Último reporte (Actual)</option>
                    {archivosHistorico.map(f => (
                    <option value={f} selected={archivoActual === f}>{formatOption(f)}</option>
                    ))}
                </select>
            </div>
          </div>

          <div class="bg-slate-50 dark:bg-white/[0.02] border border-black/5 dark:border-white/5 rounded-xl p-5 shadow-sm dark:shadow-2xl backdrop-blur-md relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-br from-green-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            <p class="font-mono text-xs tracking-widest text-slate-600 dark:text-slate-400 uppercase mb-3">
              Top 4 Candidatos (Votos Válidos)
            </p>
            <div class="space-y-3">
              {datos.resumenNacional.top4Candidatos.map((c, i) => (
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <span class="flex items-center justify-center w-5 h-5 rounded-full bg-black/10 dark:bg-white/10 text-xs font-bold text-slate-700 dark:text-slate-300">
                      {i + 1}
                    </span>
                    <span
                      class="text-sm font-medium text-slate-800 dark:text-slate-200 capitalize leading-tight"
                      style="max-width: 180px; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;"
                      title={c.nombreCandidato}
                    >
                      {c.nombreCandidato.toLowerCase()}
                    </span>
                  </div>
                  <div class="flex flex-col items-end">
                    <span class="font-mono text-xs font-bold text-primary tabular-nums">
                      {c.porcentajeVotosValidos}%
                    </span>
                    <span class="font-mono text-[9px] text-slate-600 dark:text-slate-500 tabular-nums tracking-tighter">
                      {c.totalVotosValidos.toLocaleString("es-PE")} votos
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      )
    }
  </section>

  <div
    class="overflow-x-auto rounded-lg border border-black/5 dark:border-white/5"
  >
    <table id="tabla" class="w-full text-sm">
      <thead>
        <tr
          class="border-b border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5"
        >
          <th
            data-col="nombre"
            class="th-sort px-4 py-3 text-left font-mono text-xs tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap"
          >
            Región <span class="sort-icon ml-1 opacity-40">↕</span>
          </th>
          <th
            data-col="actasContabilizadas"
            class="hidden sm:table-cell th-sort px-4 py-3 text-right font-mono text-xs tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap"
          >
            Actas ✓ <span class="sort-icon ml-1 opacity-40">↕</span>
          </th>
          <th
            data-col="porcentajeActasContabilizadas"
            class="th-sort px-4 py-3 text-left font-mono text-xs tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap"
          >
            % Contabilizadas <span class="sort-icon ml-1 opacity-40">↕</span>
          </th>
          <th
            data-col="actasPendientes"
            class="hidden sm:table-cell th-sort px-4 py-3 text-right font-mono text-xs tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap"
          >
            Actas ✗ <span class="sort-icon ml-1 opacity-40">↕</span>
          </th>
          <th
            data-col="porcentajeActasPendientes"
            class="hidden sm:table-cell th-sort px-4 py-3 text-right font-mono text-xs tracking-widest text-primary uppercase cursor-pointer select-none hover:text-primary transition-colors whitespace-nowrap"
          >
            % Pendientes <span class="sort-icon ml-1 opacity-40">↕</span>
          </th>
        </tr>
      </thead>
      <tbody id="tbody">
        {
          resultados.map((r) => (
            <tr
              class="border-b border-black/5 dark:border-white/5 hover:bg-black/[0.03] dark:hover:bg-white/[0.03] transition-colors"
              data-nombre={r.nombre}
              data-actas-contabilizadas={r.actasContabilizadas}
              data-pct-contabilizadas={r.porcentajeActasContabilizadas}
              data-actas-pendientes={r.actasPendientes}
              data-pct-pendientes={r.porcentajeActasPendientes}
            >
              <td class="px-4 py-3 font-medium text-slate-800 dark:text-slate-200 whitespace-nowrap">
                {r.nombre}
              </td>
              <td class="hidden sm:table-cell px-4 py-3 text-right font-mono text-slate-600 dark:text-slate-400">
                {r.actasContabilizadas.toLocaleString()}
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-3 min-w-[160px]">
                  <div class="flex-1 h-1.5 bg-black/10 dark:bg-white/10 rounded-full overflow-hidden">
                    <div
                      class="h-full bg-primary rounded-full"
                      style={`width: ${r.porcentajeActasContabilizadas}%`}
                    />
                  </div>
                  <span class="font-mono text-xs text-slate-700 dark:text-slate-300 w-12 text-right shrink-0">
                    {r.porcentajeActasContabilizadas}%
                  </span>
                </div>
              </td>
              <td class="hidden sm:table-cell px-4 py-3 text-right font-mono text-slate-600 dark:text-slate-400">
                {r.actasPendientes.toLocaleString()}
              </td>
              <td class="hidden sm:table-cell px-4 py-3 text-right font-mono text-slate-600 dark:text-slate-500">
                {r.porcentajeActasPendientes}%
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>

<script>
  // Handle select navigation
  document.getElementById("historialSelect")?.addEventListener("change", (e) => {
    const val = (e.target as HTMLSelectElement).value;
    if (val === "current") {
      window.location.href = "/resultados-region";
    } else {
      // Remove .json for the route
      const name = val.replace('.json', '');
      window.location.href = "/resultados-region/historico/" + name;
    }
  });

  type SortDir = "asc" | "desc";
  type ColKey =
    | "nombre"
    | "actasContabilizadas"
    | "porcentajeActasContabilizadas"
    | "actasPendientes"
    | "porcentajeActasPendientes";

  const dataAttr: Record<ColKey, string> = {
    nombre: "nombre",
    actasContabilizadas: "actasContabilizadas",
    porcentajeActasContabilizadas: "pctContabilizadas",
    actasPendientes: "actasPendientes",
    porcentajeActasPendientes: "pctPendientes",
  };

  let currentCol: ColKey | null = null;
  let currentDir: SortDir = "desc";

  const tbody = document.getElementById("tbody");
  const headers = document.querySelectorAll<HTMLTableCellElement>(".th-sort");

  if (tbody) {
    headers.forEach((th) => {
        th.addEventListener("click", () => {
        const col = th.dataset.col as ColKey;
        if (currentCol === col) {
            currentDir = currentDir === "asc" ? "desc" : "asc";
        } else {
            currentCol = col;
            currentDir = col === "nombre" ? "asc" : "desc";
        }
        sortTable(col, currentDir);
        updateIcons(th, currentDir);
        });
    });
  }

  function sortTable(col: ColKey, dir: SortDir) {
    if (!tbody) return;
    const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>("tr"));
    const attr = dataAttr[col];

    rows.sort((a, b) => {
      const av = a.dataset[attr] ?? "";
      const bv = b.dataset[attr] ?? "";
      const isNum = col !== "nombre";
      const cmp = isNum
        ? parseFloat(av) - parseFloat(bv)
        : av.localeCompare(bv, "es");
      return dir === "asc" ? cmp : -cmp;
    });

    rows.forEach((r) => tbody.appendChild(r));
  }

  function updateIcons(active: HTMLTableCellElement, dir: SortDir) {
    headers.forEach((th) => {
      const icon = th.querySelector(".sort-icon");
      if (!icon) return;
      if (th === active) {
        icon.textContent = dir === "asc" ? "↑" : "↓";
        icon.classList.remove("opacity-40");
        icon.classList.add("text-primary");
      } else {
        icon.textContent = "↕";
        icon.classList.add("opacity-40");
        icon.classList.remove("text-primary");
      }
    });
  }
</script>
